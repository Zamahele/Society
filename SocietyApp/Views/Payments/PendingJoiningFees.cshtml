@model IEnumerable<SocietyApp.Models.JoiningFeePayment>
@{ ViewData["Title"] = "Pending Joining Fees"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0" style="color:var(--navy);">Pending Joining Fee Payments</h2>
    @if (Model.Any()) { <span class="badge bg-secondary fs-6">@Model.Count() pending</span> }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No pending joining fee payments.</div>
}
else
{
    <!-- Desktop table (md+) -->
    <div class="d-none d-md-block">
        <table class="table table-hover align-middle">
            <thead style="background:var(--navy); color:#fff;">
                <tr><th>Membership No</th><th>Member Name</th><th>Amount</th><th>Reference</th><th>Payment Date</th><th>Action</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>@p.Membership.MembershipNumber</strong></td>
                        <td>@p.Membership.User.FullName</td>
                        <td>R@(p.Amount)</td>
                        <td>@p.PaymentReference</td>
                        <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <form asp-action="ConfirmJoiningFee" method="post">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-sm btn-success"
                                    data-confirm="Confirm this joining fee payment and activate membership?">
                                    Confirm
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile cards (< md) -->
    <div class="d-md-none row g-3">
        @foreach (var p in Model)
        {
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-1">@p.Membership.User.FullName</h6>
                        <small class="text-muted d-block mb-2">@p.Membership.MembershipNumber</small>
                        <div class="row small mb-3">
                            <div class="col-6"><strong>Amount:</strong> R@(p.Amount)</div>
                            <div class="col-6"><strong>Date:</strong> @p.PaymentDate.ToString("dd MMM yyyy")</div>
                            <div class="col-12"><strong>Reference:</strong> @p.PaymentReference</div>
                        </div>
                        <form asp-action="ConfirmJoiningFee" method="post">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-success w-100"
                                data-confirm="Confirm this joining fee payment and activate membership?">
                                Confirm Payment
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
