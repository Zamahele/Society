@model IEnumerable<SocietyApp.Models.JoiningFeePayment>
@{ ViewData["Title"] = "Pending Joining Fees"; }

<h2 class="mb-4">Pending Joining Fee Payments</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No pending joining fee payments.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr><th>Membership No</th><th>Member Name</th><th>Amount</th><th>Reference</th><th>Payment Date</th><th>Action</th></tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Membership.MembershipNumber</td>
                    <td>@p.Membership.User.FullName</td>
                    <td>R@(p.Amount)</td>
                    <td>@p.PaymentReference</td>
                    <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <form asp-action="ConfirmJoiningFee" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="btn btn-sm btn-success"
                                data-confirm="Confirm this joining fee payment and activate membership?">
                                Confirm
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
