@model SocietyApp.Models.Membership
@{ ViewData["Title"] = "Member Details"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@Model.User.FullName — @Model.MembershipNumber</h2>
    <a asp-action="Members" class="btn btn-outline-secondary">Back</a>
</div>

<div class="card border-warning mb-4">
    <div class="card-header bg-warning-subtle">Admin Actions</div>
    <div class="card-body d-flex flex-wrap gap-2">
        @if (Model.Status == SocietyApp.Models.MembershipStatus.Pending)
        {
            <form asp-action="ApproveMember" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success">Approve Member</button>
            </form>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Suspended)
        {
            <form asp-action="ReactivateMember" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success">Reactivate Member</button>
            </form>
        }
        else if (Model.Status == SocietyApp.Models.MembershipStatus.Active || Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment)
        {
            <form asp-action="DeactivateMember" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">Deactivate Member</button>
            </form>
        }

        <a asp-action="AddDependantForMember" asp-route-membershipId="@Model.Id" class="btn btn-dark">Add Dependant</a>

        <form asp-action="DeleteMemberData" method="post" class="row row-cols-lg-auto g-2 align-items-center ms-lg-2">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="col-12">
                <label for="confirmIdNumber" class="form-label mb-0 small">Type member ID number to permanently delete all records:</label>
            </div>
            <div class="col-12">
                <input id="confirmIdNumber" name="confirmIdNumber" class="form-control" placeholder="@Model.User.IDNumber" required />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-danger" data-confirm="This will permanently delete this member and all related records. This cannot be undone.">Delete Member Data</button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">Member Info</div>
            <div class="card-body">
                <p><strong>ID Number:</strong> @Model.User.IDNumber</p>
                <p><strong>Phone:</strong> @Model.User.Phone</p>
                <p><strong>Address:</strong> @Model.User.Address</p>
                <p><strong>Bank:</strong> @Model.User.BankName</p>
                <p><strong>Account:</strong> @Model.User.BankAccountNumber (@Model.User.BankAccountName)</p>
                <p>
                    <strong>Status:</strong>
                    @{
                        var statusBadge = Model.Status switch
                        {
                            SocietyApp.Models.MembershipStatus.Active => "bg-success",
                            SocietyApp.Models.MembershipStatus.Pending => "bg-warning text-dark",
                            SocietyApp.Models.MembershipStatus.PendingPayment => "bg-info text-dark",
                            SocietyApp.Models.MembershipStatus.Suspended => "bg-danger",
                            _ => "bg-secondary"
                        };
                        var detailStatusLabel = Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment
                            ? "Pending Payment"
                            : Model.Status.ToString();
                    }
                    <span class="badge @statusBadge">@detailStatusLabel</span>
                </p>
                <p><strong>Joined:</strong> @Model.DateIssued.ToString("dd MMM yyyy")</p>
                @if (Model.DateActivated.HasValue)
                {
                    <p><strong>Activated:</strong> @Model.DateActivated.Value.ToString("dd MMM yyyy")</p>
                }
                @if (Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment)
                {
                    <div class="alert alert-info mt-3 mb-0">
                        Member is approved, but the joining fee still needs to be paid and confirmed before activation.
                    </div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-dark text-white">Dependants (@Model.Dependants.Count)</div>
            <ul class="list-group list-group-flush">
                @foreach (var d in Model.Dependants)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@d.FullName <span class="text-muted small">(@d.Relationship)</span></span>
                        <form asp-action="RemoveDependantForMember" method="post" data-confirm="Remove this dependant? This cannot be undone.">
                            <input type="hidden" name="membershipId" value="@Model.Id" />
                            <input type="hidden" name="dependantId" value="@d.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">Monthly Payment History</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Month</th><th>Reference</th><th>Status</th><th>Confirmed By</th></tr></thead>
                    <tbody>
                        @foreach (var p in (IEnumerable<SocietyApp.Models.MonthlyPayment>)ViewBag.MonthlyHistory)
                        {
                            <tr>
                                <td>@p.ForMonth.ToString("MMM yyyy")</td>
                                <td>@p.PaymentReference</td>
                                <td><span class="badge @(p.Status == SocietyApp.Models.MonthlyPaymentStatus.Confirmed ? "bg-success" : p.Status == SocietyApp.Models.MonthlyPaymentStatus.Missed ? "bg-danger" : "bg-warning text-dark")">@p.Status</span></td>
                                <td>@(p.ConfirmedByClerk?.FullName ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-dark text-white">Claims</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Deceased</th><th>Date</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var c in (IEnumerable<SocietyApp.Models.DeathClaim>)ViewBag.Claims)
                        {
                            <tr>
                                <td>@c.DeceasedFullName</td>
                                <td>@c.ClaimDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-secondary">@c.ClaimStatus</span></td>
                                <td><a asp-controller="Claims" asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-dark">View</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
