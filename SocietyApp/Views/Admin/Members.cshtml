@model IEnumerable<SocietyApp.Models.Membership>
@{ ViewData["Title"] = "All Members"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0" style="color:var(--navy);">All Members</h2>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-secondary fs-6">@Model.Count() members</span>
        <a asp-action="CreateMember" class="btn btn-sm btn-dark">+ Create Member</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No members registered yet.</div>
}
else
{
    <!-- Desktop table (md+) -->
    <div class="d-none d-md-block">
        <table class="table table-hover align-middle">
            <thead style="background:var(--navy); color:#fff;">
                <tr><th>Membership No</th><th>Name</th><th>ID Number</th><th>Phone</th><th>Dependants</th><th>Status</th><th>Joined</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    var badge = m.Status switch
                        {
                            SocietyApp.Models.MembershipStatus.Active => "bg-success",
                            SocietyApp.Models.MembershipStatus.Pending => "bg-warning text-dark",
                            SocietyApp.Models.MembershipStatus.PendingPayment => "bg-info text-dark",
                            SocietyApp.Models.MembershipStatus.Suspended => "bg-danger",
                            SocietyApp.Models.MembershipStatus.Cancelled => "bg-dark",
                            _ => "bg-secondary"
                        };
                        var statusLabel = m.Status == SocietyApp.Models.MembershipStatus.PendingPayment ? "Pending Payment" : m.Status.ToString();
                    <tr>
                        <td><strong>@m.MembershipNumber</strong></td>
                        <td>@m.User.FullName</td>
                        <td>@m.User.IDNumber</td>
                        <td>@m.User.Phone</td>
                        <td>@m.Dependants.Count</td>
                        <td><span class="badge @badge">@statusLabel</span></td>
                        <td>@m.DateIssued.ToString("dd MMM yyyy")</td>
                        <td class="d-flex gap-2">
                            <a asp-action="MemberDetails" asp-route-id="@m.Id" class="btn btn-sm btn-outline-dark">View</a>
                            @if (m.Status == SocietyApp.Models.MembershipStatus.Pending)
                            {
                                <form asp-action="ApproveMember" method="post">
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile cards (< md) -->
    <div class="d-md-none row g-3">
        @foreach (var m in Model)
        {
            var mbadge = m.Status switch
                {
                    SocietyApp.Models.MembershipStatus.Active => "bg-success",
                    SocietyApp.Models.MembershipStatus.Pending => "bg-warning text-dark",
                    SocietyApp.Models.MembershipStatus.PendingPayment => "bg-info text-dark",
                    SocietyApp.Models.MembershipStatus.Suspended => "bg-danger",
                    SocietyApp.Models.MembershipStatus.Cancelled => "bg-dark",
                    _ => "bg-secondary"
                };
                var mLabel = m.Status == SocietyApp.Models.MembershipStatus.PendingPayment ? "Pending Payment" : m.Status.ToString();
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-bold mb-1">@m.User.FullName</h6>
                                <small class="text-muted">@m.MembershipNumber</small>
                            </div>
                            <span class="badge @mbadge">@mLabel</span>
                        </div>
                        <hr class="my-2">
                        <div class="row small">
                            <div class="col-6"><strong>ID:</strong> @m.User.IDNumber</div>
                            <div class="col-6"><strong>Phone:</strong> @m.User.Phone</div>
                            <div class="col-6"><strong>Dependants:</strong> @m.Dependants.Count</div>
                            <div class="col-6"><strong>Joined:</strong> @m.DateIssued.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="mt-3 d-flex gap-2">
                            <a asp-action="MemberDetails" asp-route-id="@m.Id" class="btn btn-sm btn-outline-dark">View</a>
                            @if (m.Status == SocietyApp.Models.MembershipStatus.Pending)
                            {
                                <form asp-action="ApproveMember" method="post">
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
