@model SocietyApp.ViewModels.CreateMemberViewModel
@{ ViewData["Title"] = "Create Member"; }

<div class="row justify-content-center">
    <div class="col-md-7">
        <h2 class="mb-4">Create New Member (Office)</h2>
        <form asp-action="CreateMember" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <h5 class="mt-3 mb-3 text-muted">Personal Details</h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="IDNumber" class="form-label"></label>
                    <input asp-for="IDNumber" class="form-control" placeholder="13-digit SA ID Number" />
                    <span asp-validation-for="IDNumber" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DateOfBirth" class="form-label"></label>
                    <input asp-for="DateOfBirth" class="form-control" type="date" readonly />
                    <small class="text-muted">Auto-filled from ID number</small>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <h5 class="mt-3 mb-3 text-muted">Banking Details (for payouts) <span class="badge bg-info">Optional — can add later</span></h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="BankName" class="form-label"></label>
                    <select asp-for="BankName" class="form-select">
                        <option value="">-- Select Bank --</option>
                        <option>Absa</option>
                        <option>African Bank</option>
                        <option>Capitec</option>
                        <option>Discovery Bank</option>
                        <option>FNB</option>
                        <option>Investec</option>
                        <option>Nedbank</option>
                        <option>Old Mutual Bank</option>
                        <option>Standard Bank</option>
                        <option>TymeBank</option>
                    </select>
                    <span asp-validation-for="BankName" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="BankAccountName" class="form-label"></label>
                    <input asp-for="BankAccountName" class="form-control" />
                    <span asp-validation-for="BankAccountName" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="BankAccountNumber" class="form-label"></label>
                    <input asp-for="BankAccountNumber" class="form-control" />
                    <span asp-validation-for="BankAccountNumber" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mt-3 mb-3 text-muted">Set Temporary Password</h5>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <small class="text-muted">Must be at least 8 characters with at least one digit.</small>
            </div>

            <button type="submit" class="btn btn-dark w-100 mt-2">Create Member</button>
            <a asp-action="Members" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function parseDobFromSaId(id) {
            id = id.replace(/\D/g, '');
            if (id.length < 6) return '';
            var yy = parseInt(id.substring(0, 2), 10);
            var mm = id.substring(2, 4);
            var dd = id.substring(4, 6);
            var currentYY = new Date().getFullYear() % 100;
            var yyyy = yy <= currentYY ? 2000 + yy : 1900 + yy;
            return yyyy + '-' + mm + '-' + dd;
        }

        document.getElementById('IDNumber').addEventListener('input', function () {
            document.getElementById('DateOfBirth').value = parseDobFromSaId(this.value);
        });
    </script>
}
