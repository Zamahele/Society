@model IList<SocietyApp.Models.ApplicationUser>
@{ ViewData["Title"] = "Clerk Accounts"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0" style="color:var(--navy);">Clerk Accounts</h2>
    <a asp-action="CreateClerk" class="btn btn-dark">+ Add Clerk</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No clerk accounts found.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:var(--navy); color:#fff;">
                    <tr>
                        <th>Name</th>
                        <th>ID Number</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var clerk in Model)
                    {
                        bool isLocked = clerk.LockoutEnd.HasValue && clerk.LockoutEnd > DateTimeOffset.UtcNow;
                        <tr>
                            <td><strong>@clerk.FullName</strong></td>
                            <td>@clerk.IDNumber</td>
                            <td>@(clerk.Email ?? "-")</td>
                            <td>
                                @if (isLocked)
                                {
                                    <span class="badge bg-danger">Deactivated</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (isLocked)
                                {
                                    <form asp-action="ActivateClerk" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@clerk.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Activate</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="DeactivateClerk" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@clerk.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning"
                                                data-confirm="Deactivate @clerk.FullName? They will not be able to log in.">
                                            Deactivate
                                        </button>
                                    </form>
                                }
                                <form asp-action="DeleteClerk" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@clerk.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            data-confirm="Permanently delete @clerk.FullName's account? This cannot be undone.">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
