<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Give Compassion NPC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Give Compassion NPC</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="#how-it-works">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="#benefits">Benefits</a></li>
                    <li class="nav-item"><a class="nav-link" href="#banking">Banking Details</a></li>
                    <li class="nav-item"><a class="nav-link" href="#committee">Committee</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-warning btn-sm ms-2 my-1" asp-controller="Account" asp-action="Register">Join Now</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="bg-dark text-light py-4 mt-0">
        <div class="container">
            <div class="row g-3 align-items-start">
                <div class="col-md-6 text-center text-md-start">
                    <p class="mb-1">&copy; @DateTime.Now.Year Give Compassion NPC. All rights reserved.</p>
                    <small class="text-muted">Caring for families in their time of need.</small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <small class="d-block text-muted">Reg No: K2026009248 / 2026/009248/08</small>
                    <small class="d-block text-muted">Type: Non Profit Company (NPC) | Status: In Business</small>
                    <small class="d-block text-muted">Registered Office: Ulundi, Kwa-Zulu Natal</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
