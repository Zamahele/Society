@using Microsoft.AspNetCore.Identity
@using SocietyApp.Models
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Society</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            @if (User.IsInRole("Admin") || User.IsInRole("Clerk"))
            {
                <a class="navbar-brand fw-bold" asp-controller="Admin" asp-action="Dashboard">Ikhaya Burial Society</a>
            }
            else if (User.IsInRole("Member"))
            {
                <a class="navbar-brand fw-bold" asp-controller="Members" asp-action="Dashboard">Ikhaya Burial Society</a>
            }
            else
            {
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Ikhaya Burial Society</a>
            }
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User.IsInRole("Member"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Members" asp-action="Dashboard">My Membership</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Members" asp-action="Dependants">Dependants</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Payments" asp-action="SubmitJoiningFee">Joining Fee</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Payments" asp-action="SubmitMonthly">Monthly Payment</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Claims" asp-action="MyClaims">My Claims</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Claims" asp-action="Submit">Submit Claim</a>
                        </li>
                    }
                    @if (User.IsInRole("Admin") || User.IsInRole("Clerk"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Members">Members</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Payments" asp-action="PendingJoiningFees">Joining Fees</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Payments" asp-action="PendingMonthly">Monthly Payments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Claims" asp-action="Index">Claims</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="CreateClerk">Create Clerk</a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        <li class="nav-item">
                            <span class="nav-link text-light">@currentUser?.FullName</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-link nav-link text-light">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
