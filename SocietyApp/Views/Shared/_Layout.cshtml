@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using SocietyApp.Models
@inject UserManager<ApplicationUser> UserManager
@inject SocietyApp.Data.AppDbContext LayoutDb
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Society</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            @if (User.IsInRole("Admin") || User.IsInRole("Clerk"))
            {
                <a class="navbar-brand fw-bold" asp-controller="Admin" asp-action="Dashboard">Give Compassion NPC</a>
            }
            else if (User.IsInRole("Member"))
            {
                <a class="navbar-brand fw-bold" asp-controller="Members" asp-action="Dashboard">Give Compassion NPC</a>
            }
            else
            {
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Give Compassion NPC</a>
            }
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User.IsInRole("Member"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Members" asp-action="Dashboard">My Membership</a>
                        </li>
                    }
                    @if (User.IsInRole("Admin") || User.IsInRole("Clerk"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Members">Members</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="PublicContent">Public Content</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Clerks">Clerks</a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        <li class="nav-item">
                            <span class="nav-link text-light">@currentUser?.FullName</span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-link nav-link text-light">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <!-- Reusable Confirm Modal -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header" style="background:var(--navy); color:#fff;">
                    <h5 class="modal-title" id="confirmModalLabel">Please Confirm</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="confirmModalMessage">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmModalOk">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    @{
        var footerSettings = await LayoutDb.PublicSiteSettings.AsNoTracking().FirstOrDefaultAsync();
    }
    <footer class="bg-dark text-light py-3 mt-4">
        <div class="container">
            <div class="row g-2 align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <small class="text-muted">&copy; @DateTime.Now.Year @(footerSettings?.OrganizationName ?? "Give Compassion NPC")</small>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    @if (!string.IsNullOrEmpty(footerSettings?.ContactPhone1))
                    {
                        <small class="text-muted me-3">@footerSettings.ContactPhone1</small>
                    }
                    @if (!string.IsNullOrEmpty(footerSettings?.ContactPhone2))
                    {
                        <small class="text-muted me-3">@footerSettings.ContactPhone2</small>
                    }
                    @if (!string.IsNullOrEmpty(footerSettings?.ContactEmailInfo))
                    {
                        <small class="text-muted">@footerSettings.ContactEmailInfo</small>
                    }
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
