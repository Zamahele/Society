@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm p-4 mt-4">
            <h1 class="text-danger mb-3">Something went wrong</h1>
            <p class="mb-2">We could not complete your request right now.</p>
            <p class="text-muted mb-4">Please try again in a moment. If the problem continues, contact support and share the request ID below.</p>

            @if (Model.ShowRequestId)
            {
                <p class="mb-0">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mt-4 d-flex gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Back to Home</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Login</a>
            </div>
        </div>
    </div>
</div>
