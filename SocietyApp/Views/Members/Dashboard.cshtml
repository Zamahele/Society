@model SocietyApp.Models.Membership
@{ ViewData["Title"] = "My Membership"; }

<h2 class="mb-4">My Membership</h2>

<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">Membership Card</div>
            <div class="card-body">
                <h4 class="card-title">@Model.MembershipNumber</h4>
                <p class="mb-1"><strong>Name:</strong> @Model.User.FullName</p>
                <p class="mb-1"><strong>ID Number:</strong> @Model.User.IDNumber</p>
                <p class="mb-1"><strong>Phone:</strong> @Model.User.Phone</p>
                <p class="mb-1">
                    <strong>Status:</strong>
                    @{
                        var badgeClass = Model.Status switch
                        {
                            SocietyApp.Models.MembershipStatus.Active => "bg-success",
                            SocietyApp.Models.MembershipStatus.Pending => "bg-warning text-dark",
                            SocietyApp.Models.MembershipStatus.PendingPayment => "bg-info text-dark",
                            SocietyApp.Models.MembershipStatus.Suspended => "bg-danger",
                            SocietyApp.Models.MembershipStatus.Cancelled => "bg-dark",
                            _ => "bg-secondary"
                        };
                        var statusLabel = Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment
                            ? "Pending Payment"
                            : Model.Status.ToString();
                    }
                    <span class="badge @badgeClass">@statusLabel</span>
                </p>
                <p class="mb-1"><strong>Joined:</strong> @Model.DateIssued.ToString("dd MMM yyyy")</p>
                @if (Model.DateActivated.HasValue)
                {
                    <p class="mb-1"><strong>Activated:</strong> @Model.DateActivated.Value.ToString("dd MMM yyyy")</p>
                }
                <p class="mb-1"><strong>Dependants:</strong> @Model.Dependants.Count / 10</p>
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <button class="btn btn-sm btn-outline-dark" type="button"
                            data-bs-toggle="collapse" data-bs-target="#editProfileForm">
                        Edit Profile
                    </button>
                    <a asp-action="BankingDetails" class="btn btn-sm btn-outline-dark">Update Banking Details</a>
                </div>
            </div>

            <div class="collapse" id="editProfileForm">
                <div class="card-body border-top">
                    <form asp-action="EditProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-2">
                            <div class="col-12">
                                <input name="FullName" class="form-control form-control-sm" placeholder="Full Name"
                                       value="@Model.User.FullName" required />
                            </div>
                            <div class="col-md-6">
                                <input name="Phone" class="form-control form-control-sm" placeholder="Phone"
                                       value="@Model.User.Phone" required />
                            </div>
                            <div class="col-md-6">
                                <input name="Address" class="form-control form-control-sm" placeholder="Address"
                                       value="@Model.User.Address" required />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#editProfileForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Pending)
        {
            <div class="alert alert-warning">
                Your membership is awaiting approval. Once approved, you will still need to pay the joining fee before your membership becomes active.
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment)
        {
            <div class="alert alert-info">
                Your membership has been approved and is now <strong>pending payment</strong>. Please pay the joining fee of <strong>R150</strong> using your membership number <strong>@Model.MembershipNumber</strong> as the EFT reference, then submit proof below.
                <div class="mt-2">
                    <a asp-controller="Payments" asp-action="SubmitJoiningFee" class="btn btn-sm btn-dark">Submit Joining Fee</a>
                </div>
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Suspended)
        {
            <div class="alert alert-danger">
                Your membership is suspended due to a missed monthly payment. Please pay R150 and submit your payment to reactivate.
                <div class="mt-2">
                    <a asp-controller="Payments" asp-action="SubmitMonthly" class="btn btn-sm btn-danger">Submit Monthly Payment</a>
                </div>
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Cancelled)
        {
            <div class="alert alert-dark">
                Your membership has been cancelled. Please contact the society for more information.
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Active && Model.DateActivated.HasValue)
        {
            var elapsed = ViewBag.WaitingMonthsElapsed as int? ?? 0;
            var eligibility = ViewBag.Eligibility as SocietyApp.Services.Interfaces.ClaimEligibilityResult;
            <div class="card mb-4">
                <div class="card-body py-2 px-3">
                    @if (eligibility?.IsEligible == true)
                    {
                        <span class="badge bg-success me-2">Claim Eligible</span>
                        <small class="text-muted">You are eligible to submit a death claim.</small>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="fw-semibold">6-month waiting period</small>
                            <small class="text-muted">@elapsed / 6 months</small>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-info" role="progressbar"
                                 style="width:@(elapsed * 100 / 6)%"></div>
                        </div>
                        <small class="text-muted d-block mt-1">Claims are enabled after 6 months of active membership.</small>
                    }
                </div>
            </div>
        }

        @* Nominee Card *@
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span>Nominee</span>
                <button class="btn btn-sm btn-outline-light" type="button"
                        data-bs-toggle="collapse" data-bs-target="#nomineeForm">
                    @(Model.Nominee != null ? "Edit" : "+ Add Nominee")
                </button>
            </div>

            <div class="collapse" id="nomineeForm">
                <div class="card-body border-bottom">
                    <form asp-action="SaveNominee" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-2">
                            <div class="col-12">
                                <input name="fullName" class="form-control form-control-sm" placeholder="Full Name" required
                                       value="@(Model.Nominee?.FullName ?? string.Empty)" />
                            </div>
                            <div class="col-md-6">
                                <input name="idNumber" class="form-control form-control-sm" placeholder="ID Number" required
                                       value="@(Model.Nominee?.IDNumber ?? string.Empty)" />
                            </div>
                            <div class="col-md-6">
                                <input name="phone" class="form-control form-control-sm" placeholder="Phone"
                                       value="@(Model.Nominee?.Phone ?? string.Empty)" />
                            </div>
                            <div class="col-12">
                                <input name="relationship" class="form-control form-control-sm" placeholder="Relationship (e.g. Spouse, Child)"
                                       value="@(Model.Nominee?.Relationship ?? string.Empty)" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save Nominee</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#nomineeForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card-body">
                @if (Model.Nominee == null)
                {
                    <p class="text-muted small mb-0">No nominee added yet. Your nominee receives the benefit if you pass away.</p>
                }
                else
                {
                    <p class="mb-1"><strong>Name:</strong> @Model.Nominee.FullName</p>
                    <p class="mb-1"><strong>ID Number:</strong> @Model.Nominee.IDNumber</p>
                    <p class="mb-1"><strong>Phone:</strong> @Model.Nominee.Phone</p>
                    <p class="mb-1"><strong>Relationship:</strong> @Model.Nominee.Relationship</p>
                    <div class="mt-2">
                        <form asp-action="RemoveNominee" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    data-confirm="Remove @Model.Nominee.FullName as your nominee? This cannot be undone.">
                                Remove Nominee
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7">
        @{
            var dependants = (IEnumerable<SocietyApp.Models.MemberDependant>)ViewBag.Dependants;
            bool canAdd = ViewBag.CanAdd;
        }
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span>Dependants (@dependants.Count() / 10)</span>
                @if (canAdd)
                {
                    <button class="btn btn-sm btn-outline-light" type="button"
                            data-bs-toggle="collapse" data-bs-target="#addDependantForm">
                        + Add Dependant
                    </button>
                }
            </div>

            <div class="collapse" id="addDependantForm">
                <div class="card-body border-bottom">
                    <form asp-action="AddDependant" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MembershipId" value="@Model.Id" />
                        <input type="hidden" name="returnTo" value="Dashboard" />
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input name="FullName" class="form-control form-control-sm" placeholder="Full Name" required />
                            </div>
                            <div class="col-md-6">
                                <input name="IDNumber" class="form-control form-control-sm" placeholder="ID Number" required />
                            </div>
                            <div class="col-md-6">
                                <input name="DateOfBirth" type="date" class="form-control form-control-sm" required />
                            </div>
                            <div class="col-md-6">
                                <select name="Relationship" class="form-select form-select-sm" required>
                                    <option value="">-- Relationship --</option>
                                    @foreach (var rel in Enum.GetValues<SocietyApp.Models.DependantRelationship>())
                                    {
                                        <option value="@rel">@rel</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save Dependant</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#addDependantForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card-body p-0">
                @if (!dependants.Any())
                {
                    <p class="text-muted small p-3 mb-0">No dependants added yet.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr><th>Name</th><th>ID Number</th><th>DOB</th><th>Relationship</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var d in dependants)
                            {
                                <tr>
                                    <td>@d.FullName</td>
                                    <td>@d.IDNumber</td>
                                    <td>@d.DateOfBirth.ToString("dd MMM yyyy")</td>
                                    <td>@d.Relationship</td>
                                    <td class="text-end">
                                        <a asp-action="EditDependant" asp-route-id="@d.Id"
                                           class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                        <form asp-action="RemoveDependant" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@d.Id" />
                                            <input type="hidden" name="returnTo" value="Dashboard" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    data-confirm="Remove @d.FullName as a dependant? This cannot be undone.">
                                                Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                @if (!canAdd)
                {
                    <p class="text-muted small px-3 py-2 mb-0">Maximum of 10 dependants reached.</p>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                Monthly Payment History
                <a asp-controller="Payments" asp-action="SubmitMonthly" class="btn btn-sm btn-outline-light">+ Submit Payment</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Month</th><th>Amount</th><th>Reference</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var p in (IEnumerable<SocietyApp.Models.MonthlyPayment>)ViewBag.MonthlyPayments)
                        {
                            <tr>
                                <td>@p.ForMonth.ToString("MMM yyyy")</td>
                                <td>R@(p.Amount)</td>
                                <td>@p.PaymentReference</td>
                                <td>
                                    <span class="badge @(p.Status == SocietyApp.Models.MonthlyPaymentStatus.Confirmed ? "bg-success" : p.Status == SocietyApp.Models.MonthlyPaymentStatus.Missed ? "bg-danger" : "bg-warning text-dark")">
                                        @p.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                Claims
                <a asp-controller="Claims" asp-action="Submit" class="btn btn-sm btn-outline-light">+ New Claim</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Deceased</th><th>Date</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var c in (IEnumerable<SocietyApp.Models.DeathClaim>)ViewBag.Claims)
                        {
                            <tr>
                                <td>@c.DeceasedFullName</td>
                                <td>@c.ClaimDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-secondary">@c.ClaimStatus</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
