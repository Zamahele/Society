@model SocietyApp.Models.Membership
@{ ViewData["Title"] = "My Membership"; }

<h2 class="mb-4">My Membership</h2>

<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">Membership Card</div>
            <div class="card-body">
                <h4 class="card-title">@Model.MembershipNumber</h4>
                <p class="mb-1"><strong>Name:</strong> @Model.User.FullName</p>
                <p class="mb-1"><strong>ID Number:</strong> @Model.User.IDNumber</p>
                <p class="mb-1"><strong>Phone:</strong> @Model.User.Phone</p>
                <p class="mb-1">
                    <strong>Status:</strong>
                    @{
                        var badgeClass = Model.Status switch
                        {
                            SocietyApp.Models.MembershipStatus.Active => "bg-success",
                            SocietyApp.Models.MembershipStatus.Pending => "bg-warning text-dark",
                            SocietyApp.Models.MembershipStatus.PendingPayment => "bg-info text-dark",
                            SocietyApp.Models.MembershipStatus.Suspended => "bg-danger",
                            SocietyApp.Models.MembershipStatus.Cancelled => "bg-dark",
                            _ => "bg-secondary"
                        };
                        var statusLabel = Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment
                            ? "Pending Payment"
                            : Model.Status.ToString();
                    }
                    <span class="badge @badgeClass">@statusLabel</span>
                </p>
                <p class="mb-1"><strong>Joined:</strong> @Model.DateIssued.ToString("dd MMM yyyy")</p>
                @if (Model.DateActivated.HasValue)
                {
                    <p class="mb-1"><strong>Activated:</strong> @Model.DateActivated.Value.ToString("dd MMM yyyy")</p>
                }
                <p class="mb-1"><strong>Dependants:</strong> @Model.Dependants.Count / 10</p>
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <button class="btn btn-sm btn-outline-dark" type="button"
                            data-bs-toggle="collapse" data-bs-target="#editProfileForm">
                        Edit Profile
                    </button>
                    <a asp-action="BankingDetails" class="btn btn-sm btn-outline-dark">Update Banking Details</a>
                </div>
            </div>

            <div class="collapse" id="editProfileForm">
                <div class="card-body border-top">
                    <form asp-action="EditProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-2">
                            <div class="col-12">
                                <input name="FullName" class="form-control form-control-sm" placeholder="Full Name"
                                       value="@Model.User.FullName" required />
                            </div>
                            <div class="col-md-6">
                                <input name="Phone" class="form-control form-control-sm" placeholder="Phone"
                                       value="@Model.User.Phone" required />
                            </div>
                            <div class="col-md-6">
                                <input name="Address" class="form-control form-control-sm" placeholder="Address"
                                       value="@Model.User.Address" required />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#editProfileForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Pending)
        {
            <div class="alert alert-warning">
                Your membership is awaiting approval. Once approved, you will still need to pay the joining fee before your membership becomes active.
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment)
        {
            var hasPending = ViewBag.HasPendingJoiningFee as bool? ?? false;
            <div class="alert alert-info">
                Your membership is approved. Pay the joining fee of <strong>R150</strong> using <strong>@Model.MembershipNumber</strong> as your EFT reference, then submit proof using the <strong>Submit Payment</strong> button in the Payment History section below.
                @if (hasPending)
                {
                    <div class="mt-2 small fw-semibold">Joining fee submitted — awaiting clerk confirmation.</div>
                }
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Suspended)
        {
            <div class="alert alert-danger">
                Your membership is suspended due to a missed monthly payment. Please pay R150 and submit your payment to reactivate.
                <div class="mt-2">
                    <button class="btn btn-sm btn-danger" type="button"
                            data-bs-toggle="collapse" data-bs-target="#submitPaymentForm">Submit Monthly Payment</button>
                </div>
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Cancelled)
        {
            <div class="alert alert-dark">
                Your membership has been cancelled. Please contact the society for more information.
            </div>
        }

        @if (Model.Status == SocietyApp.Models.MembershipStatus.Active && Model.DateActivated.HasValue)
        {
            var elapsed = ViewBag.WaitingMonthsElapsed as int? ?? 0;
            var eligibility = ViewBag.Eligibility as SocietyApp.Services.Interfaces.ClaimEligibilityResult;
            <div class="card mb-4">
                <div class="card-body py-2 px-3">
                    @if (eligibility?.IsEligible == true)
                    {
                        <span class="badge bg-success me-2">Claim Eligible</span>
                        <small class="text-muted">You are eligible to submit a death claim.</small>
                    }
                    else
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <small class="fw-semibold">6-month waiting period</small>
                            <small class="text-muted">@elapsed / 6 months</small>
                        </div>
                        <div class="progress" style="height:6px;">
                            <div class="progress-bar bg-info" role="progressbar"
                                 style="width:@(elapsed * 100 / 6)%"></div>
                        </div>
                        <small class="text-muted d-block mt-1">Claims are enabled after 6 months of active membership.</small>
                    }
                </div>
            </div>
        }

        @* Nominee Card *@
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span>Nominee</span>
                <button class="btn btn-sm btn-outline-light" type="button"
                        data-bs-toggle="collapse" data-bs-target="#nomineeForm">
                    @(Model.Nominee != null ? "Edit" : "+ Add Nominee")
                </button>
            </div>

            <div class="collapse" id="nomineeForm">
                <div class="card-body border-bottom">
                    <form asp-action="SaveNominee" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-2">
                            <div class="col-12">
                                <input name="fullName" class="form-control form-control-sm" placeholder="Full Name" required
                                       value="@(Model.Nominee?.FullName ?? string.Empty)" />
                            </div>
                            <div class="col-md-6">
                                <input name="idNumber" class="form-control form-control-sm" placeholder="ID Number" required
                                       value="@(Model.Nominee?.IDNumber ?? string.Empty)" />
                            </div>
                            <div class="col-md-6">
                                <input name="phone" class="form-control form-control-sm" placeholder="Phone"
                                       value="@(Model.Nominee?.Phone ?? string.Empty)" />
                            </div>
                            <div class="col-12">
                                <select name="relationship" class="form-select form-select-sm" required>
                                    <option value="">-- Relationship --</option>
                                    @foreach (var r in new[]{"Spouse","Partner","Child","Parent","Sibling","Friend","Other"})
                                    {
                                        <option value="@r" selected="@(Model.Nominee?.Relationship == r ? "selected" : null)">@r</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save Nominee</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#nomineeForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card-body">
                @if (Model.Nominee == null)
                {
                    <p class="text-muted small mb-0">No nominee added yet. Your nominee receives the benefit if you pass away.</p>
                }
                else
                {
                    <p class="mb-1"><strong>Name:</strong> @Model.Nominee.FullName</p>
                    <p class="mb-1"><strong>ID Number:</strong> @Model.Nominee.IDNumber</p>
                    <p class="mb-1"><strong>Phone:</strong> @Model.Nominee.Phone</p>
                    <p class="mb-1"><strong>Relationship:</strong> @Model.Nominee.Relationship</p>
                    <div class="mt-2">
                        <form asp-action="RemoveNominee" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    data-confirm="Remove @Model.Nominee.FullName as your nominee? This cannot be undone.">
                                Remove Nominee
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7">
        @{
            var dependants = (IEnumerable<SocietyApp.Models.MemberDependant>)ViewBag.Dependants;
            bool canAdd = ViewBag.CanAdd;
        }
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <span>Dependants (@dependants.Count() / 10)</span>
                @if (canAdd)
                {
                    <button class="btn btn-sm btn-outline-light" type="button"
                            data-bs-toggle="collapse" data-bs-target="#addDependantForm">
                        + Add Dependant
                    </button>
                }
            </div>

            <div class="collapse" id="addDependantForm">
                <div class="card-body border-bottom">
                    <form asp-action="AddDependant" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MembershipId" value="@Model.Id" />
                        <input type="hidden" name="returnTo" value="Dashboard" />
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input name="FullName" class="form-control form-control-sm" placeholder="Full Name" required />
                            </div>
                            <div class="col-md-6">
                                <input name="IDNumber" id="addIDNumber" class="form-control form-control-sm" placeholder="ID Number" required maxlength="13" />
                            </div>
                            <div class="col-md-6">
                                <input name="DateOfBirth" id="addDateOfBirth" type="date" class="form-control form-control-sm" readonly />
                                <small class="text-muted">Auto-filled from ID</small>
                            </div>
                            <div class="col-md-6">
                                <select name="Relationship" class="form-select form-select-sm" required>
                                    <option value="">-- Relationship --</option>
                                    @foreach (var rel in Enum.GetValues<SocietyApp.Models.DependantRelationship>())
                                    {
                                        <option value="@rel">@rel</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save Dependant</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#addDependantForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="collapse" id="editDependantForm">
                <div class="card-body border-bottom">
                    <form asp-action="EditDependant" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" id="editId" />
                        <input type="hidden" name="MembershipId" value="@Model.Id" />
                        <input type="hidden" name="returnTo" value="Dashboard" />
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input name="FullName" id="editFullName" class="form-control form-control-sm" placeholder="Full Name" required />
                            </div>
                            <div class="col-md-6">
                                <input name="IDNumber" id="editIDNumber" class="form-control form-control-sm" placeholder="ID Number" required maxlength="13" />
                            </div>
                            <div class="col-md-6">
                                <input name="DateOfBirth" id="editDateOfBirth" type="date" class="form-control form-control-sm" readonly />
                                <small class="text-muted">Auto-filled from ID</small>
                            </div>
                            <div class="col-md-6">
                                <select name="Relationship" id="editRelationship" class="form-select form-select-sm" required>
                                    @foreach (var rel in Enum.GetValues<SocietyApp.Models.DependantRelationship>())
                                    {
                                        <option value="@rel">@rel</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Save Changes</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#editDependantForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card-body p-0">
                @if (!dependants.Any())
                {
                    <p class="text-muted small p-3 mb-0">No dependants added yet.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th class="d-none d-md-table-cell">ID Number</th>
                                <th class="d-none d-md-table-cell">DOB</th>
                                <th>Relationship</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in dependants)
                            {
                                <tr>
                                    <td>@d.FullName</td>
                                    <td class="d-none d-md-table-cell">@d.IDNumber</td>
                                    <td class="d-none d-md-table-cell">@d.DateOfBirth.ToString("dd MMM yyyy")</td>
                                    <td>@d.Relationship</td>
                                    <td class="text-end text-nowrap">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary me-1"
                                                title="Edit @d.FullName"
                                                data-dep-id="@d.Id"
                                                data-dep-name="@d.FullName"
                                                data-dep-idnumber="@d.IDNumber"
                                                data-dep-dob="@d.DateOfBirth.ToString("yyyy-MM-dd")"
                                                data-dep-relationship="@d.Relationship"
                                                onclick="openEditDependant(this)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form asp-action="RemoveDependant" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@d.Id" />
                                            <input type="hidden" name="returnTo" value="Dashboard" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    title="Remove @d.FullName"
                                                    data-confirm="Remove @d.FullName as a dependant? This cannot be undone.">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                @if (!canAdd)
                {
                    <p class="text-muted small px-3 py-2 mb-0">Maximum of 10 dependants reached.</p>
                }
            </div>
        </div>

        @{
            var hasPendingFee = ViewBag.HasPendingJoiningFee as bool? ?? false;
            var canSubmitJoiningFee = Model.Status == SocietyApp.Models.MembershipStatus.PendingPayment && !hasPendingFee;
            var canSubmitMonthly = Model.Status == SocietyApp.Models.MembershipStatus.Active || Model.Status == SocietyApp.Models.MembershipStatus.Suspended;
            var showSubmitBtn = canSubmitJoiningFee || canSubmitMonthly;
        }
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                Payment History
                @if (showSubmitBtn)
                {
                    <button class="btn btn-sm btn-outline-light" type="button"
                            data-bs-toggle="collapse" data-bs-target="#submitPaymentForm">+ Submit Payment</button>
                }
            </div>
            <div class="collapse" id="submitPaymentForm">
                <div class="card-body border-bottom">
                    <div class="alert alert-info py-2 px-3 mb-3 small">
                        <strong>Bank:</strong> Capitec &nbsp;|&nbsp;
                        <strong>Account Name:</strong> Give Compassion NPC &nbsp;|&nbsp;
                        <strong>Account No:</strong> 1054981680 &nbsp;|&nbsp;
                        <strong>Branch:</strong> 450105
                    </div>
                    <form asp-controller="Payments" asp-action="SubmitPayment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MembershipId" value="@Model.Id" />
                        <input type="hidden" name="MembershipNumber" value="@Model.MembershipNumber" />
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Payment Type</label>
                                <select name="PaymentType" id="paymentType" class="form-select form-select-sm" required>
                                    @if (canSubmitJoiningFee)
                                    {
                                        <option value="JoiningFee">Joining Fee</option>
                                    }
                                    @if (canSubmitMonthly)
                                    {
                                        <option value="Monthly">Monthly Payment</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4" id="forMonthRow" style="@(canSubmitMonthly && !canSubmitJoiningFee ? "" : "display:none;")">
                                <label class="form-label form-label-sm">For Month</label>
                                <input name="ForMonth" id="forMonth" type="date" class="form-control form-control-sm"
                                       value="@(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).ToString("yyyy-MM-dd"))" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">Date Paid</label>
                                <input name="PaymentDate" type="date" class="form-control form-control-sm"
                                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label form-label-sm">EFT Reference</label>
                                <input name="PaymentReference" class="form-control form-control-sm" placeholder="Reference" required />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Submit</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#submitPaymentForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card-body p-0">
                @{
                    var joiningFees = (IEnumerable<SocietyApp.Models.JoiningFeePayment>)ViewBag.JoiningFeePayments;
                    var monthlyPayments = (IEnumerable<SocietyApp.Models.MonthlyPayment>)ViewBag.MonthlyPayments;
                }
                <table class="table table-sm mb-0">
                    <thead><tr><th>Type</th><th>Date</th><th>Reference</th><th>Amount</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var p in joiningFees)
                        {
                            var jfBadge = p.Status == SocietyApp.Models.PaymentStatus.Confirmed ? "bg-success" : "bg-warning text-dark";
                            <tr>
                                <td><span class="badge bg-secondary">Joining Fee</span></td>
                                <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                <td>@p.PaymentReference</td>
                                <td>R@(p.Amount)</td>
                                <td><span class="badge @jfBadge">@p.Status</span></td>
                            </tr>
                        }
                        @foreach (var p in monthlyPayments)
                        {
                            var mpBadge = p.Status == SocietyApp.Models.MonthlyPaymentStatus.Confirmed ? "bg-success" : p.Status == SocietyApp.Models.MonthlyPaymentStatus.Missed ? "bg-danger" : "bg-warning text-dark";
                            <tr>
                                <td><span class="badge bg-info text-dark">@p.ForMonth.ToString("MMM yyyy")</span></td>
                                <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                                <td>@p.PaymentReference</td>
                                <td>R@(p.Amount)</td>
                                <td><span class="badge @mpBadge">@p.Status</span></td>
                            </tr>
                        }
                        @if (!joiningFees.Any() && !monthlyPayments.Any())
                        {
                            <tr><td colspan="5" class="text-muted small py-3 text-center">No payment records yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                Claims
                @{
                    var claimElig = ViewBag.Eligibility as SocietyApp.Services.Interfaces.ClaimEligibilityResult;
                }
                @if (claimElig?.IsEligible == true)
                {
                    <button class="btn btn-sm btn-outline-light" type="button"
                            data-bs-toggle="collapse" data-bs-target="#submitClaimForm">+ New Claim</button>
                }
            </div>
            <div class="collapse" id="submitClaimForm">
                <div class="card-body border-bottom">
                    <form asp-controller="Claims" asp-action="Submit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MembershipId" value="@Model.Id" />
                        <input type="hidden" name="returnTo" value="Dashboard" />
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">Who Passed Away</label>
                                <select name="DeceasedType" id="claimDeceasedType" class="form-select form-select-sm" required>
                                    @foreach (var dt in Enum.GetValues<SocietyApp.Models.DeceasedType>())
                                    {
                                        <option value="@dt">@dt</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6" id="claimDependantRow" style="display:none;">
                                <label class="form-label form-label-sm">Dependant</label>
                                <select name="DependantId" class="form-select form-select-sm">
                                    <option value="">-- Select Dependant --</option>
                                    @foreach (var dep in (IEnumerable<SocietyApp.Models.MemberDependant>)ViewBag.Dependants)
                                    {
                                        <option value="@dep.Id">@dep.FullName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">Full Name of Deceased</label>
                                <input name="DeceasedFullName" class="form-control form-control-sm" placeholder="Full name" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label form-label-sm">Date of Death</label>
                                <input name="DateOfDeath" type="date" class="form-control form-control-sm" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label form-label-sm">Death Certificate (PDF/JPG/PNG)</label>
                                <input name="DeathCertificate" type="file" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-sm btn-dark">Submit Claim</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="collapse" data-bs-target="#submitClaimForm">Cancel</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead><tr><th>Deceased</th><th>Date</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var c in (IEnumerable<SocietyApp.Models.DeathClaim>)ViewBag.Claims)
                        {
                            <tr>
                                <td>@c.DeceasedFullName</td>
                                <td>@c.ClaimDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-secondary">@c.ClaimStatus</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function parseDobFromSaId(id) {
            id = id.replace(/\D/g, '');
            if (id.length < 6) return '';
            var yy = parseInt(id.substring(0, 2), 10);
            var mm = id.substring(2, 4);
            var dd = id.substring(4, 6);
            var currentYY = new Date().getFullYear() % 100;
            var yyyy = yy <= currentYY ? 2000 + yy : 1900 + yy;
            return yyyy + '-' + mm + '-' + dd;
        }

        var addId = document.getElementById('addIDNumber');
        if (addId) addId.addEventListener('input', function () {
            document.getElementById('addDateOfBirth').value = parseDobFromSaId(this.value);
        });

        document.getElementById('editIDNumber').addEventListener('input', function () {
            document.getElementById('editDateOfBirth').value = parseDobFromSaId(this.value);
        });

        var paymentTypeEl = document.getElementById('paymentType');
        if (paymentTypeEl) {
            paymentTypeEl.addEventListener('change', function () {
                var forMonthRow = document.getElementById('forMonthRow');
                var forMonth = document.getElementById('forMonth');
                var isMonthly = this.value === 'Monthly';
                forMonthRow.style.display = isMonthly ? '' : 'none';
                forMonth.required = isMonthly;
            });
        }

        document.getElementById('claimDeceasedType')?.addEventListener('change', function () {
            document.getElementById('claimDependantRow').style.display = this.value === 'Dependant' ? '' : 'none';
        });

        function openEditDependant(btn) {
            document.getElementById('editId').value = btn.dataset.depId;
            document.getElementById('editFullName').value = btn.dataset.depName;
            document.getElementById('editIDNumber').value = btn.dataset.depIdnumber;
            document.getElementById('editDateOfBirth').value = btn.dataset.depDob;
            document.getElementById('editRelationship').value = btn.dataset.depRelationship;

            bootstrap.Collapse.getOrCreateInstance(document.getElementById('addDependantForm')).hide();
            bootstrap.Collapse.getOrCreateInstance(document.getElementById('editDependantForm')).show();
            document.getElementById('editDependantForm').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    </script>
}
