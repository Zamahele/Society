@model SocietyApp.ViewModels.AddDependantViewModel
@{ ViewData["Title"] = "Add Dependant"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Add Dependant</h2>
        <form asp-action="AddDependant" method="post">
            <input type="hidden" asp-for="MembershipId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="IDNumber" class="form-label"></label>
                <input asp-for="IDNumber" class="form-control" id="IDNumber" maxlength="13" />
                <span asp-validation-for="IDNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DateOfBirth" class="form-label"></label>
                <input asp-for="DateOfBirth" class="form-control" type="date" id="DateOfBirth" readonly />
                <span asp-validation-for="DateOfBirth" class="text-danger small text-muted">Auto-filled from ID number</span>
            </div>
            <div class="mb-3">
                <label asp-for="Relationship" class="form-label"></label>
                <select asp-for="Relationship" class="form-select"
                    asp-items="Html.GetEnumSelectList<SocietyApp.Models.DependantRelationship>()"></select>
                <span asp-validation-for="Relationship" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-dark">Add Dependant</button>
            <a asp-action="Dependants" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('IDNumber').addEventListener('input', function () {
            var id = this.value.replace(/\D/g, '');
            if (id.length >= 6) {
                var yy = parseInt(id.substring(0, 2), 10);
                var mm = id.substring(2, 4);
                var dd = id.substring(4, 6);
                var currentYY = new Date().getFullYear() % 100;
                var yyyy = yy <= currentYY ? 2000 + yy : 1900 + yy;
                document.getElementById('DateOfBirth').value = yyyy + '-' + mm + '-' + dd;
            } else {
                document.getElementById('DateOfBirth').value = '';
            }
        });
    </script>
}
