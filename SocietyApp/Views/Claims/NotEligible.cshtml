@{ ViewData["Title"] = "Not Eligible"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="alert alert-danger mt-4">
            <h4>You are not eligible to submit a claim at this time.</h4>
            <ul class="mb-0 mt-2">
                @foreach (var reason in (List<string>)ViewBag.Reasons)
                {
                    <li>@reason</li>
                }
            </ul>
        </div>
        <a asp-controller="Members" asp-action="Dashboard" class="btn btn-dark">Back to Dashboard</a>
    </div>
</div>
