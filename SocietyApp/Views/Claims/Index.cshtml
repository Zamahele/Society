@model IEnumerable<SocietyApp.Models.DeathClaim>
@{ ViewData["Title"] = "All Claims"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0" style="color:var(--navy);">All Claims</h2>
    @if (Model.Any()) { <span class="badge bg-secondary fs-6">@Model.Count() claims</span> }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No claims in the system.</div>
}
else
{
    <!-- Desktop table (md+) -->
    <div class="d-none d-md-block">
        <table class="table table-hover align-middle">
            <thead style="background:var(--navy); color:#fff;">
                <tr><th>Membership No</th><th>Member</th><th>Deceased</th><th>Claim Date</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var badge = c.ClaimStatus switch
                        {
                            SocietyApp.Models.ClaimStatus.FullyPaid => "bg-success",
                            SocietyApp.Models.ClaimStatus.Approved => "bg-primary",
                            SocietyApp.Models.ClaimStatus.Rejected => "bg-danger",
                            SocietyApp.Models.ClaimStatus.PartiallyPaid => "bg-info text-dark",
                            _ => "bg-warning text-dark"
                        };
                    <tr>
                        <td><strong>@c.Membership.MembershipNumber</strong></td>
                        <td>@c.Membership.User.FullName</td>
                        <td>@c.DeceasedFullName</td>
                        <td>@c.ClaimDate.ToString("dd MMM yyyy")</td>
                        <td><span class="badge @badge">@c.ClaimStatus</span></td>
                        <td><a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-dark">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile cards (< md) -->
    <div class="d-md-none row g-3">
        @foreach (var c in Model)
        {
            var mbadge = c.ClaimStatus switch
                {
                    SocietyApp.Models.ClaimStatus.FullyPaid => "bg-success",
                    SocietyApp.Models.ClaimStatus.Approved => "bg-primary",
                    SocietyApp.Models.ClaimStatus.Rejected => "bg-danger",
                    SocietyApp.Models.ClaimStatus.PartiallyPaid => "bg-info text-dark",
                    _ => "bg-warning text-dark"
                };
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-bold mb-1">@c.Membership.User.FullName</h6>
                                <small class="text-muted">@c.Membership.MembershipNumber</small>
                            </div>
                            <span class="badge @mbadge">@c.ClaimStatus</span>
                        </div>
                        <hr class="my-2">
                        <div class="row small">
                            <div class="col-6"><strong>Deceased:</strong> @c.DeceasedFullName</div>
                            <div class="col-6"><strong>Claim Date:</strong> @c.ClaimDate.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="mt-3">
                            <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-dark">View</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
