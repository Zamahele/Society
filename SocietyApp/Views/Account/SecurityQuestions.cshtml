@model SocietyApp.ViewModels.SecurityQuestionsViewModel
@{ ViewData["Title"] = "Verify Identity"; }

<div class="row justify-content-center mt-5">
    <div class="col-12 col-sm-9 col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-sm-5">
                <h2 class="fw-bold mb-1" style="color:#1a3a52;">Verify Your Identity</h2>
                <p class="text-muted mb-4">Answer the questions below to confirm it's you.</p>

                <form asp-action="SecurityQuestions" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                        <input asp-for="DateOfBirth" class="form-control form-control-lg" type="date" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Phone" class="form-label fw-semibold">Phone Number on Your Account</label>
                        <input asp-for="Phone" class="form-control form-control-lg" placeholder="e.g. 0721234567" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Verify</button>
                    <a asp-action="ForgotPassword" class="btn btn-outline-secondary w-100 mt-2">Back</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
