@model SocietyApp.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; }

<div class="auth-page d-flex align-items-center justify-content-center" style="min-height: auto; padding: 2rem 0;">
    <div class="w-100">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6">
                <div class="text-center mb-4">
                    <h1 class="fw-bold mb-2" style="color: #1a3a52;">Give Compassion NPC</h1>
                    <p class="text-muted mb-3">Funeral Benefit Society</p>
                </div>

                <div class="card shadow-lg border-0">
                    <div class="card-body p-4 p-sm-5">
                        <h2 class="card-title text-center mb-2" style="color: #1a3a52; font-size: 1.75rem;">New Member Registration</h2>

                        <!-- Step indicators -->
                        <div class="d-flex justify-content-center align-items-center gap-2 mb-4">
                            <span id="step-indicator-1" class="badge bg-primary">1 Personal</span>
                            <span class="text-muted">›</span>
                            <span id="step-indicator-2" class="badge bg-secondary">2 Nominee</span>
                            <span class="text-muted">›</span>
                            <span id="step-indicator-3" class="badge bg-secondary">3 Password</span>
                        </div>

                        <form asp-action="Register" method="post" id="registerForm">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <strong>Please fix the following errors:</strong>
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <div>• @error.ErrorMessage</div>
                                    }
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <!-- Step 1: Personal Details -->
                            <div id="step-1">
                                <h5 class="fw-semibold mb-4" style="color: #1a3a52;">
                                    <span class="badge bg-primary me-2">1</span> Personal Details
                                </h5>

                                <div class="mb-3">
                                    <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                                    <input asp-for="FullName" class="form-control" placeholder="e.g. John Doe" />
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="IDNumber" class="form-label fw-semibold">ID Number</label>
                                            <input asp-for="IDNumber" class="form-control" placeholder="13-digit SA ID" />
                                            <span asp-validation-for="IDNumber" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                                            <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="Phone" class="form-label fw-semibold">Phone Number</label>
                                            <input asp-for="Phone" class="form-control" placeholder="e.g. 0721234567" />
                                            <span asp-validation-for="Phone" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="Address" class="form-label fw-semibold">Address</label>
                                            <input asp-for="Address" class="form-control" placeholder="Your home address" />
                                            <span asp-validation-for="Address" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end mt-3">
                                    <button type="button" class="btn btn-primary" onclick="goToStep(2)" style="background-color: #1a3a52; border: none;">
                                        Next: Nominee &rarr;
                                    </button>
                                </div>
                            </div>

                            <!-- Step 2: Nominee (optional) -->
                            <div id="step-2" style="display:none;">
                                <h5 class="fw-semibold mb-1" style="color: #1a3a52;">
                                    <span class="badge bg-primary me-2">2</span> Nominee
                                </h5>
                                <p class="text-muted small mb-4">
                                    A nominee receives your benefit if you pass away. You can also add or update this later from your Dashboard.
                                </p>

                                <div class="mb-3">
                                    <label asp-for="NomineeFullName" class="form-label fw-semibold">Full Name</label>
                                    <input asp-for="NomineeFullName" class="form-control" placeholder="e.g. Jane Doe" />
                                </div>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="NomineeIDNumber" class="form-label fw-semibold">ID Number</label>
                                            <input asp-for="NomineeIDNumber" class="form-control" placeholder="13-digit SA ID" />
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="NomineePhone" class="form-label fw-semibold">Phone</label>
                                            <input asp-for="NomineePhone" class="form-control" placeholder="e.g. 0831234567" />
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="NomineeRelationship" class="form-label fw-semibold">Relationship</label>
                                    <input asp-for="NomineeRelationship" class="form-control" placeholder="e.g. Spouse, Child, Sibling" />
                                </div>

                                <div class="d-flex justify-content-between mt-3">
                                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(1)">&larr; Back</button>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-outline-secondary" onclick="skipNominee()">Skip for now</button>
                                        <button type="button" class="btn btn-primary" onclick="goToStep(3)" style="background-color: #1a3a52; border: none;">
                                            Next: Password &rarr;
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 3: Password -->
                            <div id="step-3" style="display:none;">
                                <h5 class="fw-semibold mb-4" style="color: #1a3a52;">
                                    <span class="badge bg-success me-2">3</span> Create Password
                                </h5>
                                <p class="small text-muted mb-3">At least 8 characters with at least one number</p>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                                            <input asp-for="Password" class="form-control" type="password" placeholder="Create a password" />
                                            <span asp-validation-for="Password" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm password" />
                                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between mt-3">
                                    <button type="button" class="btn btn-outline-secondary" onclick="goToStep(2)">&larr; Back</button>
                                    <button type="submit" class="btn btn-primary btn-lg fw-semibold" style="background-color: #1a3a52; border: none;">Create My Account</button>
                                </div>
                            </div>
                        </form>

                        <hr class="my-4" />
                        <div class="text-center">
                            <p class="mb-0 text-muted">Already a member? <a asp-action="Login" class="fw-semibold" style="color: #1a3a52;">Login here</a></p>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info mt-4" role="alert">
                    <strong>Safe &amp; Secure:</strong> Your data is encrypted and protected. No spam, no sharing with third parties.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        var currentStep = 1;

        // If there are validation errors, show the first step that has errors
        document.addEventListener('DOMContentLoaded', function () {
            var hasErrors = document.querySelector('.alert-danger') !== null;
            if (hasErrors) {
                showStep(1);
            } else {
                showStep(1);
            }
        });

        function showStep(n) {
            currentStep = n;
            document.getElementById('step-1').style.display = n === 1 ? '' : 'none';
            document.getElementById('step-2').style.display = n === 2 ? '' : 'none';
            document.getElementById('step-3').style.display = n === 3 ? '' : 'none';

            ['step-indicator-1', 'step-indicator-2', 'step-indicator-3'].forEach(function (id, i) {
                var el = document.getElementById(id);
                el.classList.remove('bg-primary', 'bg-secondary', 'bg-success');
                if (i + 1 < n) el.classList.add('bg-success');
                else if (i + 1 === n) el.classList.add('bg-primary');
                else el.classList.add('bg-secondary');
            });
        }

        function goToStep(n) {
            showStep(n);
        }

        function skipNominee() {
            document.getElementById('NomineeFullName').value = '';
            document.getElementById('NomineeIDNumber').value = '';
            document.getElementById('NomineePhone').value = '';
            document.getElementById('NomineeRelationship').value = '';
            goToStep(3);
        }
    </script>
}
