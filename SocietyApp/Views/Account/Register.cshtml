@model SocietyApp.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Register"; }

<div class="auth-page d-flex align-items-center justify-content-center" style="min-height: auto; padding: 2rem 0;">
    <div class="w-100">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6">
                <!-- Header -->
                <div class="text-center mb-4">
                    <h1 class="fw-bold mb-2" style="color: #1a3a52;">Give Compassion NPC</h1>
                    <p class="text-muted mb-3">Funeral Benefit Society</p>
                </div>

                <!-- Registration Card -->
                <div class="card shadow-lg border-0">
                    <div class="card-body p-4 p-sm-5">
                        <h2 class="card-title text-center mb-2" style="color: #1a3a52; font-size: 1.75rem;">New Member Registration</h2>
                        <p class="text-center text-muted small mb-4">Join our community in 2 simple steps</p>

                        <form asp-action="Register" method="post">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    <strong>Please fix the following errors:</strong>
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <div>• @error.ErrorMessage</div>
                                    }
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <!-- Step 1: Personal Details -->
                            <div class="mb-5">
                                <h5 class="fw-semibold mb-4" style="color: #1a3a52;">
                                    <span class="badge bg-primary me-2">1</span> Personal Details
                                </h5>

                                <div class="mb-3">
                                    <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                                    <input asp-for="FullName" class="form-control" placeholder="e.g. John Doe" />
                                </div>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="IDNumber" class="form-label fw-semibold">ID Number</label>
                                            <input asp-for="IDNumber" class="form-control" placeholder="13-digit SA ID" />
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth</label>
                                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="Phone" class="form-label fw-semibold">Phone Number</label>
                                            <input asp-for="Phone" class="form-control" placeholder="e.g. 0721234567" />
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="Address" class="form-label fw-semibold">Address</label>
                                            <input asp-for="Address" class="form-control" placeholder="Your home address" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr />

                            <!-- Step 2: Create Password -->
                            <div class="mb-5">
                                <h5 class="fw-semibold mb-4" style="color: #1a3a52;">
                                    <span class="badge bg-success me-2">2</span> Create Password
                                </h5>
                                <p class="small text-muted mb-3">At least 8 characters with at least one number</p>

                                <div class="row">
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                                            <input asp-for="Password" class="form-control" type="password" placeholder="Create a password" />
                                        </div>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <div class="mb-3">
                                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm password" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-semibold" style="background-color: #1a3a52; border: none;">Create My Account</button>
                        </form>

                        <hr class="my-4" />

                        <div class="text-center">
                            <p class="mb-0 text-muted">Already a member? <a asp-action="Login" class="fw-semibold" style="color: #1a3a52;">Login here</a></p>
                        </div>
                    </div>
                </div>

                <!-- Footer Info -->
                <div class="alert alert-info mt-4" role="alert">
                    <strong>Safe & Secure:</strong> Your data is encrypted and protected. No spam, no sharing with third parties.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
