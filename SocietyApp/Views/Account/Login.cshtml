@model SocietyApp.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Login"; }

<div class="auth-page d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="w-100">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-6 col-lg-5">
                <!-- Header -->
                <div class="text-center mb-5">
                    <h1 class="fw-bold mb-2" style="color: #1a3a52;">Give Compassion NPC</h1>
                    <p class="text-muted">Funeral Benefit Society</p>
                </div>

                <!-- Login Card -->
                <div class="card shadow-lg border-0">
                    <div class="card-body p-4 p-sm-5">
                        <h2 class="card-title text-center mb-4" style="color: #1a3a52; font-size: 1.75rem;">Member Login</h2>

                        <form asp-action="Login" method="post">
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                            
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <div>@error.ErrorMessage</div>
                                    }
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <div class="mb-4">
                                <label asp-for="IDNumber" class="form-label fw-semibold">ID Number</label>
                                <input asp-for="IDNumber" class="form-control form-control-lg" placeholder="Enter your 13-digit SA ID" autocomplete="username" />
                            </div>

                            <div class="mb-4">
                                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                                <input asp-for="Password" class="form-control form-control-lg" placeholder="Enter your password" autocomplete="current-password" />
                            </div>

                            <div class="mb-4 form-check">
                                <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe" />
                                <label class="form-check-label" for="rememberMe">Remember me</label>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-semibold" style="background-color: #1a3a52; border: none;">Login</button>
                        </form>

                        <hr class="my-4" />

                        <div class="text-center">
                            <p class="mb-2 text-muted">Don't have an account? <a asp-action="Register" class="fw-semibold" style="color: #1a3a52;">Register here</a></p>
                            <p class="mb-0"><a asp-action="ForgotPassword" class="text-muted small">Forgot your password?</a></p>
                        </div>
                    </div>
                </div>

                <!-- Footer Help -->
                <div class="text-center mt-4">
                    <small class="text-muted">Need help? Contact our support team</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
