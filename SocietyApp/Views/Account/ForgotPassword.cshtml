@model SocietyApp.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; }

<div class="row justify-content-center mt-5">
    <div class="col-12 col-sm-9 col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-sm-5">
                <h2 class="fw-bold mb-1" style="color:#1a3a52;">Reset Password</h2>
                <p class="text-muted mb-4">Enter your SA ID number to find your account.</p>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="IDNumber" class="form-label fw-semibold">ID Number</label>
                        <input asp-for="IDNumber" class="form-control form-control-lg" placeholder="13-digit SA ID" />
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Continue</button>
                    <a asp-action="Login" class="btn btn-outline-secondary w-100 mt-2">Back to Login</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
