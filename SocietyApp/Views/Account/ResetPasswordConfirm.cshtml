@model SocietyApp.ViewModels.ResetPasswordConfirmViewModel
@{ ViewData["Title"] = "Set New Password"; }

<div class="row justify-content-center mt-5">
    <div class="col-12 col-sm-9 col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-sm-5">
                <h2 class="fw-bold mb-1" style="color:#1a3a52;">Set New Password</h2>
                <p class="text-muted mb-4">Choose a new password for your account.</p>

                <form asp-action="ResetPasswordConfirm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold">New Password</label>
                        <input asp-for="NewPassword" class="form-control form-control-lg" type="password" placeholder="At least 8 characters" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg" type="password" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100">Reset Password</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
